{
  "name": "umple",
  "displayName": "Umple",
  "description": "Language server for the Umple modeling language",
  "version": "2.1.0",
  "publisher": "digized",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/umple/umple.vscode"
  },
  "engines": {
    "vscode": "^1.108.0"
  },
  "main": "./out/extension.js",
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "npm run compile && node out/commands/diagramWorkspace.test.js",
    "vscode:prepublish": "npm run compile"
  },
  "contributes": {
    "commands": [
      {
        "command": "umple.compile",
        "title": "Umple: Compile"
      },
      {
        "command": "umple.showDiagram",
        "title": "Umple: Show Diagram"
      },
      {
        "command": "umple.selectLanguage",
        "title": "Umple: Select Target Language"
      },
      {
        "command": "umple.menu",
        "title": "Umple",
        "icon": {
          "light": "images/icon-light.svg",
          "dark": "images/icon-dark.svg"
        }
      }
    ],
    "keybindings": [
      {
        "command": "umple.showDiagram",
        "key": "ctrl+shift+u",
        "mac": "cmd+shift+u",
        "when": "editorLangId == umple"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "umple.menu",
          "when": "editorLangId == umple",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Umple",
      "properties": {
        "umple.autoUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically update umplesync.jar to the latest version on startup."
        },
        "umple.generateLanguage": {
          "type": "string",
          "default": "Java",
          "enum": [
            "Java",
            "Php",
            "Ruby",
            "Python",
            "Cpp",
            "RTCpp",
            "Sql"
          ],
          "description": "Target language for Umple code generation."
        },
        "umple.diagramLayout": {
          "type": "string",
          "default": "dot",
          "enum": [
            "dot",
            "circo",
            "neato",
            "fdp",
            "osage"
          ],
          "enumDescriptions": [
            "Hierarchical/layered layout (default)",
            "Circular layout",
            "Spring-model layout",
            "Force-directed layout",
            "Clustered/grid layout"
          ],
          "description": "Layout engine for diagram rendering."
        }
      }
    },
    "snippets": [
      {
        "language": "umple",
        "path": "./snippets/umple.json"
      }
    ],
    "languages": [
      {
        "id": "umple",
        "aliases": [
          "Umple",
          "umple"
        ],
        "extensions": [
          ".ump"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "umple",
        "scopeName": "source.umple",
        "path": "./syntaxes/umple.tmLanguage"
      }
    ]
  },
  "dependencies": {
    "@viz-js/viz": "^3.24.0",
    "umple-lsp-server": "*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.108.1",
    "typescript": "^5.7.2"
  }
}
